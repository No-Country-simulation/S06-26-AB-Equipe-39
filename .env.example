# ===========================================
# App BiT — variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA suba o .env.
# ===========================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados
DATABASE_URL=postgresql://user:pass@localhost:5432/appbit

# Agente de IA (LLM)
LLM_API_KEY=coloque-sua-chave-aqui
LLM_MODEL=claude-...

# Dataset Vísent CDRView (opcional)
# https://github.com/wongola-bit/appbit
CDRVIEW_PATH=./data/cdrview.csv

# Multilíngue (pt | es)
DEFAULT_LOCALE=pt
