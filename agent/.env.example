# ==========================================================
# Google Gemini
# ==========================================================

# API Key
GEMINI_API_KEY=

# Modelo da IA
GEMINI_MODEL=gemini-2.5-flash

# ==========================================================
# Configuração da geração
# ==========================================================

TEMPERATURE=0.7
MAX_OUTPUT_TOKENS=2048
TOP_P=0.95
TOP_K=40

# Tempo máximo da requisição (segundos)
REQUEST_TIMEOUT=60
